# =========================================
# AI-Native Mall — Environment Variables
# 复制为 .env 后填入实际值
# =========================================

# Backend
DB_PASSWORD=1234
REDIS_HOST=localhost
REDIS_PORT=6380

# AI Model (LangChain4j — 通义千问/DeepSeek)
AI_API_KEY=sk-your-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-max

# Playwright E2E
TEST_ENV=local
# TEST_ENV=ci  (CI pipeline)
# TEST_ENV=staging  (pre-prod)

# Ops Monitor
OPS_BACKEND_URL=http://localhost:8081
OPS_ALERT_EMAIL=ops@company.com
OPS_CPU_THRESHOLD=80
OPS_MEMORY_THRESHOLD=85
OPS_DISK_THRESHOLD=90

# Admin
APP_ADMIN_IDS=1,2

# Test profile
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_NAME=ai_mall_test
TEST_DB_USERNAME=root
TEST_DB_PASSWORD=1234
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6380

# Figma MCP
FIGMA_API_KEY=your-figma-api-key

# Postman MCP
POSTMAN_API_KEY=your-postman-api-key
