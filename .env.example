# ==================== 环境变量配置示例 ====================
# 复制此文件为 .env 并根据实际情况修改
# 注意：.env 文件不应提交到版本控制系统

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_mall
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DATABASE=0

# ==================== Elasticsearch配置 ====================
ES_URIS=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=your_es_secure_password

# ==================== AI模型配置 ====================
# 通义千问
AI_API_KEY=sk-your-tongyi-api-key-here
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-max
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
AI_TOP_P=0.8

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ==================== JWT安全配置 ====================
# 重要：生产环境必须使用强随机字符串（至少256位）
# 生成方法：openssl rand -base64 64
JWT_SECRET=change-this-to-a-secure-random-string-at-least-256-bits-long-in-production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
JWT_HEADER=Authorization
JWT_PREFIX="Bearer "

# ==================== Nacos配置中心 ====================
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ==================== RocketMQ消息队列 ====================
ROCKETMQ_NAME_SERVER=localhost:9876

# ==================== Sentinel流量防护 ====================
SENTINEL_DASHBOARD=localhost:8080
